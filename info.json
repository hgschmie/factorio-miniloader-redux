{
  "name": "miniloader-redux",
  "version": "1.0.1",
  "title": "Miniloader (Redux)",
  "description": "UPS-friendly 1x1 loaders.",
  "author": "hgschmie",
  "contact": "https://github.com/hgschmie/factorio-miniloader-redux/issues/",
  "homepage": "https://github.com/hgschmie/factorio-miniloader-redux",
  "factorio_version": "2.0",
  "dependencies": [
    "base >= 2.0.59",
    "(?) matts-logistics",
    "(?) Krastorio2 >= 2.0.7",
    "(?) boblogistics >= 2.1.0",
    "(?) Load-Furn-2-SpaceAgeFix",
    "(?) space-exploration",
    "(?) TurboBelt"
  ],
  "package": {
    "git_publish_branch": "main",
    "readme": "README.md",
    "gallery": [
	  "portal/all-belts.gif",
      "portal/all-belts-stacked.gif",
	  "portal/lane-filter.gif",
	  "portal/sideloading.gif",
	  "portal/normal-mode-gui.png",
	  "portal/speed-mode-gui.png",
	  "portal/extended_rotation.gif",
	  "portal/picker-dollies.gif"
    ],
    "sync_portal_details": true,
    "ignore": [
      "**/*.xcf",
      "**/.zip",
      ".DS_Store",
      ".claude/*",
      ".git",
      ".gitattributes",
      ".gitignore",
      ".vscode",
      "claude-issues.md",
      "graphics/**/*.webp",
      "portal/*",
      "releases/*"
    ]
  }
}
